# ============================================================================
# MODEL & DATA FILES (Large binary artifacts)
# ============================================================================
# Raw datasets - exclude to avoid committing large files
data/*.csv
data/*.zip
data/*.tar.gz
data/*.7z
!data/.gitkeep

# Processed data
data/processed/
!data/processed/.gitkeep

# Trained models - exclude to avoid committing large binaries
models/*.joblib
models/*.pkl
models/*.pickle
models/*.h5
models/*.pt
models/*.pth
models/*.model
!models/.gitkeep

# SHAP & Explainability artifacts
assets/shap_explanations/
!assets/shap_explanations/.gitkeep

# EDA reports (regenerable)
assets/eda_reports/
!assets/eda_reports/.gitkeep

