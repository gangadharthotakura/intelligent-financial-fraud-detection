# ============================================================================
# PROJECT-SPECIFIC EXCLUSIONS
# ============================================================================
# Large dataset files (use DVC or data versioning instead)
data/creditcard.csv
data/raw/*
!data/raw/.gitkeep

# Model artifacts (use model versioning instead)
models/**/*.joblib
!models/.gitkeep

# EDA output (regenerable, exclude to keep repo clean)
assets/eda_reports/**/*.html
assets/shap_explanations/**/*.html
!assets/eda_reports/.gitkeep
!assets/shap_explanations/.gitkeep

# Database files
*.db
*.sqlite
*.sqlite3

# Pickle files (potential security risk)
*.pkl
*.pickle

